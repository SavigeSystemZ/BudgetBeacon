# Budget Beacon uses Vite 8 while vite-plugin-pwa@1.2.0 still declares a peer
# range up to Vite 7. The combination works in practice (PWA build verified),
# but strict peer resolution (npm install / npm ci) errors with ERESOLVE.
# legacy-peer-deps keeps installs reproducible across local + CI until
# vite-plugin-pwa widens its peer range.
legacy-peer-deps=true
