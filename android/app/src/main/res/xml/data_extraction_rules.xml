<?xml version="1.0" encoding="utf-8"?>
<!--
  Budget Beacon data is end-to-end encrypted client-side; we explicitly opt out
  of Android Auto Backup / device-to-device transfer so household ciphertext is
  never copied off-device through OS-level channels.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
