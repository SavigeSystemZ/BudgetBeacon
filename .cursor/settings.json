{
  "_comment": "Per-app preserve-first Cursor project settings. Customize freely. The meta-managed sibling .cursor/settings.aiaast.json carries fleet-wide policy and must not be edited here. See _system/HOST_SETTINGS_BASELINE.md.",
  "rulesFile": ".cursorrules",
  "mcp": {
    "servers": [],
    "servers_pointer": "_system/MCP_CONFIG.md",
    "servers_example_json": "_system/mcp/servers.cursor.example.json"
  },
  "indexing": {
    "include": [],
    "exclude": [
      "_system/history/**",
      "_system/automation/*.log",
      "_system/automation/*.json",
      "_system/agent-state/**",
      ".git/**",
      "node_modules/**",
      "__pycache__/**"
    ]
  },
  "instructions": {
    "context_files": [
      "AGENTS.md",
      "CURSOR.md",
      ".cursorrules",
      "_system/INSTRUCTION_PRECEDENCE_CONTRACT.md",
      "_system/REPO_OPERATING_PROFILE.md",
      "_system/MASTER_SYSTEM_PROMPT.md",
      "_system/PROJECT_RULES.md",
      "_system/EXECUTION_PROTOCOL.md",
      "_system/MULTI_AGENT_COORDINATION.md",
      "_system/HALLUCINATION_DEFENSE_PROTOCOL.md",
      "_system/SYSTEM_AWARENESS_PROTOCOL.md",
      "_system/TOOL_MEMORY_ISOLATION_STAMP.md"
    ]
  },
  "tool_memory": {
    "stamp_helper": "bootstrap/stamp-tool-memory.sh",
    "stamp_contract": "_system/TOOL_MEMORY_ISOLATION_STAMP.md",
    "memory_file": "_system/tool-memory/cursor-memory.md"
  },
  "integrity": {
    "verify_before_handoff": true,
    "verify_command": "bash bootstrap/verify-integrity.sh --check --target .",
    "verify_meta_sync_before_handoff": true,
    "meta_sync_gate_command": "bash bootstrap/check-pending-meta-sync.sh .",
    "meta_sync_reconcile_command": "bash bootstrap/reconcile-meta-sync.sh ."
  },
  "env_hint": {
    "AIAST_HOST_ADAPTER": "cursor"
  }
}
